# === Auth ===
DASHBOARD_PASSWORD=change-me-to-a-32-char-random-string
TOTP_SECRET=base32-secret-from-otpauth-uri
SESSION_SECRET=64-char-random-string-for-cookie-signing
BACKUP_CODES_HASHED=hash1,hash2,hash3,hash4,hash5,hash6,hash7,hash8

# === Bot push ===
BOT_PUSH_TOKEN=64-char-random-string-shared-with-github-actions

# === Fundamentals + earnings (yfinance Python edge function) ===
# Shared secret between the TS proxy (/api/fundamentals-proxy) and the Python
# function (/api/fundamentals.py). The proxy gates on session auth then forwards
# X-Internal-Auth so only it can hit the Python function. Generate any 32+ char
# random string and set the SAME value in Vercel env.
INTERNAL_FUNCTIONS_TOKEN=64-char-random-string-shared-with-fundamentals-py

# === Alpaca paper accounts ===
ALPACA_API_KEY=PKxxxxxxxxxxx
ALPACA_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_AGG_API_KEY=PKxxxxxxxxxxx
ALPACA_AGG_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_MANUAL_API_KEY=PKxxxxxxxxxxx
ALPACA_MANUAL_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# === AI grading (Claude Sonnet) ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx

# === Cron token (auto-grade open trades) ===
# Shared secret for cron-job.org → /api/cron/grade-open-trades. Same value
# is set on cron-job.org as the Authorization: Bearer header.
CRON_TOKEN=64-char-random-string-shared-with-cron-job-org

# === Alpaca data ===
# Same key works for market data on paper account
ALPACA_DATA_BASE_URL=https://data.alpaca.markets/v2

# === Vercel KV (Upstash Redis) — auto-provisioned by the Marketplace integration ===
# DO NOT set these manually in .env — they come from the integration.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
